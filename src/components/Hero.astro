---
import { siteConfig } from "../config";
---

<section id="about" class="pt-28 pb-10 sm:pt-36 sm:pb-16">
  <!-- Top: Name + tagline + CTA -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center mb-16 sm:mb-20">
    <h1 class="text-3xl sm:text-5xl font-bold text-text-primary mb-6 leading-tight">
      {siteConfig.name}
    </h1>

    <p class="text-lg sm:text-xl text-text-secondary leading-relaxed mb-10 max-w-2xl mx-auto">
      {siteConfig.tagline}
    </p>

    {siteConfig.links.whatsapp && (
      <a
        href={siteConfig.links.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-brand text-white font-semibold hover:bg-brand-dark transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Join our WhatsApp Group
      </a>
    )}
  </div>

  <!-- What we do + City image -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- What we do -->
      <div>
        <h2 class="text-2xl font-bold text-text-primary mb-4">What we do</h2>
        <p class="text-text-secondary leading-relaxed mb-5">
          {siteConfig.description}
        </p>
        <p class="text-text-secondary mb-4">We do so by:</p>
        <ul class="space-y-3 text-text-secondary">
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Educating ourselves with reading groups, workshops, events, and discussions.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Connecting with a community of people dedicated to this problem worldwide.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Supporting each other in making long-term plans to contribute to AI Safety through our career, engagement, or advocacy.</span>
          </li>
        </ul>
      </div>

      <!-- City image -->
      <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
        <img
          src={siteConfig.cityImage || "/city.jpg"}
          alt={`${siteConfig.city} skyline`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <!-- Dark overlay for dark mode compatibility -->
        <div class="absolute inset-0 bg-gradient-to-t from-bg/60 via-transparent to-bg/20"></div>
      </div>
    </div>
  </div>
</section>
