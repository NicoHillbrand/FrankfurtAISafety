---
import { siteConfig } from "../config";
---

<section id="about" class="pt-28 pb-10 sm:pt-36 sm:pb-16">
  <!-- Top: Logo + Name + tagline + CTA -->
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center mb-16 sm:mb-20">
    <h1 class="text-3xl sm:text-5xl font-bold text-text-primary mb-4 leading-tight">
      {siteConfig.name}
    </h1>

    <p class="text-base sm:text-lg text-text-secondary italic mb-6">Learn. Build. Impact. Together</p>

    <p class="text-lg sm:text-xl text-text-secondary leading-relaxed mb-10 max-w-2xl mx-auto">
      {siteConfig.tagline}
    </p>

    <a
      href={siteConfig.links.signupForm}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-brand text-bg font-semibold hover:bg-brand-dark transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
        <circle cx="9" cy="7" r="4" />
        <line x1="19" y1="8" x2="19" y2="14" />
        <line x1="22" y1="11" x2="16" y2="11" />
      </svg>
      Sign up to become a Member
    </a>
  </div>

  <!-- What we do + City image -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- What we do -->
      <div>
        <h2 class="text-2xl font-bold text-text-primary mb-4">What we do</h2>
        <p class="text-text-secondary leading-relaxed mb-5">
          {siteConfig.description}
        </p>
        <p class="text-text-secondary mb-4">We do so by:</p>
        <ul class="space-y-3 text-text-secondary">
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Educating ourselves with reading groups, workshops, events, and discussions.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Connecting with a community of people dedicated to this problem worldwide.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-1.5 h-1.5 rounded-full bg-brand mt-2 shrink-0"></span>
            <span>Supporting each other in making long-term plans to contribute to AI Safety through our career, engagement, or advocacy.</span>
          </li>
        </ul>
      </div>

      <!-- City image -->
      <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
        <img
          src={siteConfig.cityImage || "/city.jpg"}
          alt={`${siteConfig.city} skyline`}
          class="w-full h-full object-cover"
          loading="lazy"
        />
        <!-- Dark overlay for dark mode compatibility -->
        <div class="absolute inset-0 bg-gradient-to-t from-bg/60 via-transparent to-bg/20"></div>
      </div>
    </div>
  </div>

  <!-- Meetup Photos -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 mt-16 sm:mt-20">
    <h2 class="text-2xl font-bold text-text-primary mb-6 text-center">Our First Meetup</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="relative rounded-xl overflow-hidden aspect-[4/3]">
        <img src="/meetup1.jpg" alt="Frankfurt AI Safety first meetup" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="relative rounded-xl overflow-hidden aspect-[4/3]">
        <img src="/meetup2.jpg" alt="Frankfurt AI Safety meetup discussion" class="w-full h-full object-cover" loading="lazy" />
      </div>
      <div class="relative rounded-xl overflow-hidden aspect-[4/3]">
        <img src="/meetup3.jpg" alt="Frankfurt AI Safety meetup networking" class="w-full h-full object-cover" loading="lazy" />
      </div>
    </div>
  </div>
</section>
