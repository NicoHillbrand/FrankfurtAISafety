---
import { siteConfig } from "../config";
---

<footer class="border-t border-border py-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
      <div>
        &copy; {new Date().getFullYear()} {siteConfig.name}
      </div>
      <div class="flex items-center gap-4">
        <a href="/imprint" class="hover:text-text-secondary transition-colors">Imprint</a>
        <a href="/privacy" class="hover:text-text-secondary transition-colors">Privacy</a>
        {siteConfig.links.email && (
          <a href={`mailto:${siteConfig.links.email}`} class="hover:text-text-secondary transition-colors">
            {siteConfig.links.email}
          </a>
        )}
        {siteConfig.saige.affiliated && (
          <a href={siteConfig.saige.url} target="_blank" rel="noopener noreferrer" class="hover:text-text-secondary transition-colors">
            SAIGE
          </a>
        )}
      </div>
    </div>
  </div>
</footer>
