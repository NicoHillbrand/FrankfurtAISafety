---
import { siteConfig } from "../config";
---

<section id="resources" class="py-16 sm:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-10 text-center">
      Resources
    </h2>

    {Object.entries(siteConfig.resources).map(([category, items]) => (
      <div class="mb-10 last:mb-0">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-4">{category}</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {items.map((resource) => (
            <a
              href={resource.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-start justify-between gap-3 p-4 rounded-xl bg-bg-card border border-border hover:border-border-light hover:bg-bg-card-hover transition-all"
            >
              <div>
                <h4 class="font-medium text-text-primary group-hover:text-brand-light transition-colors text-sm">
                  {resource.title}
                </h4>
                <p class="text-xs text-text-muted mt-1">{resource.description}</p>
              </div>
              <svg class="w-3.5 h-3.5 text-text-muted group-hover:text-brand-light shrink-0 mt-0.5 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
