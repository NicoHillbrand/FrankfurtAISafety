---
import { siteConfig } from "../config";
---

<section id="mentors" class="py-16 sm:py-20 fade-in-section">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-4">Become a Mentor</h2>
    <p class="text-text-secondary leading-relaxed mb-8 max-w-2xl mx-auto">
      Are you experienced in AI safety, machine learning, policy, or a related field? Help guide the next generation of AI safety researchers and practitioners in Frankfurt.
    </p>
    <a
      href={siteConfig.links.mentorForm}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-brand text-brand font-semibold hover:bg-brand hover:text-bg transition-colors"
    >
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
        <circle cx="9" cy="7" r="4" />
        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
      </svg>
      Expression of Interest for Mentors
    </a>
  </div>
</section>
