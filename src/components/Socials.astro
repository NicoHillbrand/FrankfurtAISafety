---
import { siteConfig } from "../config";
---

<section id="socials" class="py-16 sm:py-20 fade-in-section">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-2xl sm:text-3xl font-bold text-text-primary mb-4">Follow Us</h2>
    <p class="text-text-secondary mb-8">Stay up to date with our events and community</p>
    <div class="flex items-center justify-center gap-6">
      <a
        href={siteConfig.links.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-6 py-3 rounded-xl bg-bg-card border border-border hover:border-brand hover:bg-bg-card-hover transition-colors"
      >
        <svg class="w-6 h-6 text-text-primary" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        <span class="text-text-primary font-medium">LinkedIn</span>
      </a>
      <a
        href={siteConfig.links.meetup}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-6 py-3 rounded-xl bg-bg-card border border-border hover:border-brand hover:bg-bg-card-hover transition-colors"
      >
        <svg class="w-6 h-6 text-text-primary" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.98 2a2.49 2.49 0 0 0-2.4 1.81L2.1 13.24a2.1 2.1 0 0 0 .17 1.57 2.09 2.09 0 0 0 1.24.97l.52.15a1.58 1.58 0 0 0 1.76-.68l3.4-5.26a.28.28 0 0 1 .52.14v7.2a1.74 1.74 0 0 0 1.6 1.74 1.71 1.71 0 0 0 1.82-1.71v-4.62a.27.27 0 0 1 .54 0v4.34a1.74 1.74 0 0 0 1.6 1.74 1.71 1.71 0 0 0 1.83-1.71V12.1a.27.27 0 0 1 .53 0v3.22a1.58 1.58 0 0 0 1.46 1.58 1.55 1.55 0 0 0 1.65-1.55v-4.46a.27.27 0 0 1 .54 0v1.89a1.18 1.18 0 0 0 1.09 1.18A1.16 1.16 0 0 0 24 12.8V8.2a6.22 6.22 0 0 0-6.22-6.22z" />
        </svg>
        <span class="text-text-primary font-medium">Meetup</span>
      </a>
    </div>
  </div>
</section>
